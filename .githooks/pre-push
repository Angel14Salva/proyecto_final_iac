#!/bin/sh

# Pre-push hook: corre tests de integracion solo si Docker esta disponible
# Si Docker no esta corriendo, avisa y permite el push sin bloquear

echo "[pre-push] Verificando entorno Docker..."

if ! docker info > /dev/null 2>&1; then
  echo "[pre-push] Docker no esta disponible en esta maquina."
  echo "[pre-push] Los tests de integracion se ejecutaran en GitHub Actions."
  echo "[pre-push] Push continuando..."
  exit 0
fi

echo "[pre-push] Docker disponible. Ejecutando tests del backend..."

cd apps/backend || exit 1

./mvnw -B clean verify -q
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo "[pre-push] Tests fallando. Revisa los errores antes de hacer push."
  exit 1
fi

echo "[pre-push] Todos los tests pasaron. Push permitido."
exit 0
